{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "#/*": ["./src/*"],
      "@/*": ["./src/*"],
      "#/components/ui/*": ["./node_modules/@beskid/ui-react/src/components/ui/*"],
      "#/lib/utils": ["./node_modules/@beskid/ui-react/src/lib/utils.ts"],
      "#/lib/utils.ts": ["./node_modules/@beskid/ui-react/src/lib/utils.ts"],
      "#/hooks/use-mobile": ["./node_modules/@beskid/ui-react/src/hooks/use-mobile.ts"],
      "#/hooks/use-mobile.ts": ["./node_modules/@beskid/ui-react/src/hooks/use-mobile.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
