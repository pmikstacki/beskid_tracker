{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beskid-lang.org/schemas/seed/deliverable.schema.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "closedOn": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "subtasks": {
      "default": [],
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "done": {
            "default": false,
            "type": "boolean"
          }
        },
        "required": [
          "text",
          "done"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "id",
    "title",
    "subtasks"
  ],
  "additionalProperties": false
}
