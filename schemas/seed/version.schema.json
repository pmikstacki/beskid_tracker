{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beskid-lang.org/schemas/seed/version.schema.json",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "Planned",
        "In Progress",
        "Released"
      ]
    },
    "cutoff": {
      "type": "object",
      "properties": {
        "startDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "endDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "startCommitSha": {
          "type": "string"
        },
        "endCommitSha": {
          "type": "string",
          "minLength": 7
        },
        "endCommitRepo": {
          "type": "string",
          "enum": [
            "beskid",
            "compiler",
            "pckg",
            "site",
            "beskid_vscode"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "startDate",
        "endDate",
        "endCommitSha",
        "endCommitRepo",
        "rationale"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "id",
    "title",
    "summary",
    "theme",
    "cutoff"
  ],
  "additionalProperties": false
}
