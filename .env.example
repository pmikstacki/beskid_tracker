# Copy to .env before `bun run dev`.
# GitHub OAuth runs only on the shared auth hub — see site/auth/README.md

AUTH_HUB_PUBLIC_URL=http://localhost:8090
SESSION_SECRET=dev-session-secret-at-least-32-characters-long

# Optional: legacy fallback if pairing has not stored a service token yet
# AUTH_HUB_SECRET=

GITHUB_REPO_OWNER=Cyber-Nomad-Collective
GITHUB_REPO_NAME=beskid

# Optional PATs for bug export/import (not user OAuth)
# GITHUB_PUBLIC_READ_TOKEN=
# GITHUB_SYNC_TOKEN=

TRACKER_PUBLIC_URL=http://localhost:3000
# GITHUB_WEBHOOK_SECRET=

# Skip strict env validation in local dev without a running hub
# SKIP_ENV_VALIDATION=1
