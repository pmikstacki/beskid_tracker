# Copy to .env before `bun run dev` when using GitHub OAuth locally:
#   cp .env.example .env
#
# Dev placeholders below pass T3Env validation; replace with real OAuth App values for sign-in.

GITHUB_CLIENT_ID=dev-github-client-id
GITHUB_CLIENT_SECRET=dev-github-client-secret-placeholder
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback

# openssl rand -base64 32
SESSION_SECRET=dev-session-secret-must-be-at-least-32-bytes-long

GITHUB_REPO_OWNER=Cyber-Nomad-Collective
GITHUB_REPO_NAME=beskid

# PAT for background issue sync (preferred). Falls back to GITHUB_PUBLIC_READ_TOKEN.
# GITHUB_SYNC_TOKEN=ghp_...

# Optional: fine-grained PAT with Issues read (used for sync when GITHUB_SYNC_TOKEN unset)
# GITHUB_PUBLIC_READ_TOKEN=ghp_...

# SQLite issue mirror (default: data/runtime/issues.sqlite)
# TRACKER_DATA_DIR=data/runtime

# Stale-after interval for background refresh (default 5 minutes)
# ISSUES_SYNC_STALE_MS=300000

# Set to 0 to skip sync on first request after startup
# ISSUES_SYNC_ON_START=1

# Set to 1 to disable GitHub sync entirely (read-only empty store)
# ISSUES_SYNC_DISABLED=1

VITE_GITHUB_REPO_DISPLAY_NAME=beskid

# Read roadmap board/workstreams from data/seed/ instead of GitHub Issues (read-only)
# ROADMAP_USE_SEED=1

# Docker build only (runtime still needs secrets above in production)
# SKIP_ENV_VALIDATION=1
